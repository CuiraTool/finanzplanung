{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Stryker Mutation-Testing Setup. Mutiert Engine-Code, prüft ob Tests fehlschlagen. Niedriger Score = Lücken in Tests. Ziel: 80%+ Mutation-Score.",
  "packageManager": "pnpm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/engine/ahv.ts",
    "src/engine/bvg.ts",
    "src/engine/steuer.ts",
    "src/engine/hinterlassenen.ts",
    "src/engine/erbschaftssteuer.ts",
    "src/engine/repartition.ts",
    "src/engine/economy-defaults.ts"
  ],
  "thresholds": {
    "high": 85,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 30000,
  "concurrency": 4
}
